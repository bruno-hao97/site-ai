# Gommo upstream (proxy server)
GOMMO_API_BASE_URL=https://v2.api.gommo.net
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo
# Merchant token — server Railway dùng để sendBalances sau PayOS webhook
GOMMO_ACCESS_TOKEN=
GOMMO_API_DOMAIN=vmedia.ai

# Server (Railway tự set PORT)
PORT=3001

# App URL (frontend Vercel)
APP_URL=https://trungtamai.vn

# Topup: quy đổi VND → credit
TOPUP_MIN_VND=10000
TOPUP_MAX_VND=20000000
TOPUP_CREDITS_PER_VND=1
# Buffer merchant trước khi cho tạo lệnh PayOS (cần khả dụng >= credits gói + buffer;
# đồng thời sau trừ phải còn > 500000 theo rule Gommo)
TOPUP_MERCHANT_BUFFER_CREDITS=300000

# PayOS (server-side only — điền key thật trong .env, không commit)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Webhook URL công khai trên Railway
PAYOS_WEBHOOK_URL=https://api.trungtamai.vn/api/payos/webhook

# Telegram bot (site-ai) — tạo bot qua @BotFather
TELEGRAM_BOT_TOKEN=
# Public webhook trên Railway
TELEGRAM_WEBHOOK_URL=https://api.trungtamai.vn/api/telegram/webhook
# Secret tùy chọn (setWebhook + verify header)
TELEGRAM_WEBHOOK_SECRET=
# Chat ID nhận cảnh báo topup (lấy bằng /chatid trên bot), nhiều id cách nhau dấu phẩy
TELEGRAM_NOTIFY_CHAT_IDS=

# Ops status chi tiết (GET /api/ops/status) — nếu trống, dùng TELEGRAM_WEBHOOK_SECRET làm x-ops-key
OPS_STATUS_KEY=
