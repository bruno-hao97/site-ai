# Gommo API (jobs/models — server-side)
GOMMO_API_BASE_URL=https://v2.api.gommo.net
# Gommo auth (/ai/me — đăng nhập token như vmedia)
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo
GOMMO_ACCESS_TOKEN=your_gommo_token_here
GOMMO_DOMAIN=vmedia.ai
GOMMO_PROJECT_ID=default

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3001

# Credits
SIGNUP_BONUS_CREDITS=1000
IMAGE_JOB_COST=10
VIDEO_JOB_COST=25

# Google OAuth (cùng Client ID cho server + Vite)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# App URL (link reset mật khẩu)
APP_URL=http://localhost:5173
DEV_RETURN_RESET_LINK=true
PASSWORD_RESET_EXPIRES_HOURS=1
ALLOW_MOCK_TOPUP=true
FIRST_TOPUP_BONUS_PERCENT=10
