# Gommo upstream (proxy server)
GOMMO_API_BASE_URL=https://v2.api.gommo.net
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo

# Server
PORT=3001

# App URL (pricing, external links)
APP_URL=http://localhost:5173

# PayOS (server-side only — điền key thật trong .env, không commit)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Webhook URL công khai, vd. https://your-domain.com/api/payos/webhook
PAYOS_WEBHOOK_URL=
